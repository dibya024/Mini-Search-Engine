{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Search Engine",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/Document.cpp",
                "${workspaceFolder}/src/DocumentLoader.cpp",
                "-o",
                "${workspaceFolder}/build/SearchEngine.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}